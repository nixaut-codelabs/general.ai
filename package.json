{
  "name": "@lightining/general.ai",
  "version": "1.2.0-beta.1",
  "description": "Beta-stage TypeScript-first OpenAI-compatible orchestration runtime with native passthrough, protocol-guided agents, provider key rotation, request queueing, tools, subagents, context management, and streaming.",
  "license": "Apache-2.0",
  "author": "Nixaut CodeLabs",
  "homepage": "https://github.com/nixaut-codelabs/general.ai#readme",
  "bugs": {
    "url": "https://github.com/nixaut-codelabs/general.ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nixaut-codelabs/general.ai.git"
  },
  "keywords": [
    "openai",
    "openai-compatible",
    "openai-api",
    "responses",
    "chat-completions",
    "agent",
    "agents",
    "ai-agent",
    "agent-runtime",
    "orchestration",
    "llm-orchestration",
    "runtime",
    "ai-runtime",
    "llm",
    "llm-runtime",
    "typescript",
    "node",
    "bun",
    "prompt-engineering",
    "prompt-runtime",
    "prompt-orchestration",
    "protocol-guided",
    "prompt-protocol",
    "context-management",
    "context-compression",
    "context-window",
    "memory",
    "reasoning",
    "model-intelligence",
    "prompt-adaptation",
    "adaptive-prompting",
    "thinking",
    "streaming",
    "compatibility",
    "presets",
    "provider-compatibility",
    "multi-provider",
    "provider-routing",
    "api-key-rotation",
    "rate-limit",
    "request-queue",
    "scheduler",
    "retry",
    "observability",
    "debugging",
    "subagents",
    "multi-agent",
    "subagent-runtime",
    "tool-calling",
    "tool-orchestration",
    "chatbot-framework",
    "nvidia-nim",
    "openai-sdk",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && node scripts/copy-prompts.mjs",
    "test": "npm run build && node --test test/**/*.test.js",
    "test:full": "npm run build && bun run test.js",
    "smoke": "npm run build && node test/smoke/node-smoke.mjs && bun test/smoke/bun-smoke.mjs",
    "examples": "npm run build && node examples/native-responses.mjs",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test && npm run smoke && npm run pack:check"
  },
  "dependencies": {
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  }
}
